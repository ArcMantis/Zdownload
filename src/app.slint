import { Button, VerticalBox, HorizontalBox, LineEdit, ScrollView, GroupBox, ComboBox } from "std-widgets.slint";

export component MainWindow inherits Window {
    title: "Zdownload";
    preferred-width: 850px;
    preferred-height: 650px;
    min-width: 700px;
    min-height: 550px;

    in-out property <bool> is-chinese: true;

    in-out property <string> url: "";
    out property <string> cookie-path-default-cn: "未选择文件(可选)";
    out property <string> cookie-path-default-en: "No file selected (Optional)";
    in-out property <string> cookie-path: is-chinese ?  cookie-path-default-cn: cookie-path-default-en;
    in-out property <string> log-text: "";
    in-out property <int> selected-quality-idx: 1; 
    in-out property <bool> downloading: false;

    callback download-clicked();
    callback cancel-clicked();
    callback select-cookie-clicked();
    callback clear-cookie-clicked();
    callback clear-url-clicked();

    background: @linear-gradient(180deg, #f5f7f9 0%, #ffffff 100%);
    default-font-family: "sans-serif"; 
    default-font-size: 14px;

    VerticalBox {
        padding: 30px; 
        spacing: 25px; 

        // 1. Download Configuration Group
        GroupBox {
            title: is-chinese ? "下载任务配置" : "Download Configuration";
            vertical-stretch: 0;
            VerticalBox {
                spacing: 15px; 
                padding: 15px;
                
                // URL Bar
                HorizontalBox {
                    spacing: 15px;
                    Text { 
                        text: is-chinese ? "视频链接:" : "Video URL:"; 
                        vertical-alignment: center; 
                        width: 100px; // 稍微加宽一点以适配英文长度
                        font-weight: 600; 
                        color: #4a5568; 
                    }
                    LineEdit {
                        text <=> root.url;
                        placeholder-text: is-chinese ? "在此粘贴视频地址..." : "Paste video link here...";
                        enabled: !root.downloading;
                        height: 40px; 
                    }
                    if (root.url != "") : Button {
                        text: is-chinese ? "清除" : "Clear";
                        width: 70px;
                        height: 40px;
                        enabled: !root.downloading;
                        clicked => { root.clear-url-clicked(); }
                    }
                }

                // Cookies Bar
                HorizontalBox {
                    spacing: 15px;
                    Text { 
                        text: "Cookies"; 
                        vertical-alignment: center; 
                        width: 100px; 
                        font-weight: 600;
                        color: #4a5568;
                    }
                    Rectangle {
                        background: #edf2f7; 
                        border-radius: 8px; 
                        horizontal-stretch: 1;
                        height: 40px;
                        HorizontalBox {
                            padding-left: 12px;
                            Text { 
                                text: root.cookie-path; 
                                vertical-alignment: center; 
                                // 根据语言判断默认文本颜色
                                color: (root.cookie-path == "未选择文件(可选)" || root.cookie-path == "No file selected (Optional)") ? #a0aec0 : #2d3748;
                                overflow: elide;
                                font-size: 13px;
                            }
                        }
                    }
                    Button {
                        text: is-chinese ? "选择文件" : "Browse";
                        width: 100px;
                        height: 40px;
                        enabled: !root.downloading;
                        clicked => { root.select-cookie-clicked() }
                    }
                    if (root.cookie-path != (is-chinese ? "未选择文件(可选)" : "No file selected (Optional)")) : Button {
                        text: is-chinese ? "移除" : "Remove";
                        width: 70px;
                        height: 40px;
                        enabled: !root.downloading;
                        clicked => { root.clear-cookie-clicked() }
                    }
                }

                // Quality
                HorizontalBox {
                    spacing: 15px;
                    Text { 
                        text: is-chinese ? "优先画质:" : "Quality:"; 
                        vertical-alignment: center; 
                        width: 100px; 
                        font-weight: 600;
                        color: #4a5568;
                    }
                    ComboBox {
                        model: ["4K (2160p)", "1080p (Full HD)", "720p (HD)", "480p","MP3"];
                        current-index <=> root.selected-quality-idx;
                        enabled: !root.downloading;
                        height: 40px;
                    }
                    Rectangle { } 
                }
            }
        }

        // 2. Controls
        HorizontalBox {
            alignment: center;
            spacing: 30px;
            vertical-stretch: 0;
            
            Button {
                text: is-chinese ? "开始下载" : "Start Download";
                primary: true;
                width: 200px;
                height: 50px;
                enabled: !root.downloading; 
                clicked => { root.download-clicked(); }
            }

            Button {
                text: is-chinese ? "取消下载" : "Cancel";
                width: 200px;
                height: 50px;
                clicked => { root.cancel-clicked(); }
            }
        }

        // 3. Log window
        VerticalBox {
            vertical-stretch: 1;
            spacing: 10px;
            Text { 
                text: is-chinese ? "执行日志" : "Execution Logs"; 
                font-size: 14px; 
                font-weight: 700; 
                color: #718096; 
            }
            Rectangle {
                background: #ffffff;
                border-width: 1.5px; 
                border-color: #e2e8f0; 
                border-radius: 12px; 
                clip: true;
                
                log-scroll := ScrollView {
                    viewport-height: log-layout.preferred-height;
                    
                    log-layout := VerticalBox {
                        padding: 20px; 
                        Text {
                            text: root.log-text;
                            font-family: "monospace"; 
                            font-size: 16px; 
                            wrap: word-wrap;
                            color: #2d3748;
                        }
                    }
                }
            }
        }
    }

    // Auto-scroll
    changed log-text => {
        if (log-scroll.viewport-height > log-scroll.visible-height) {
            log-scroll.viewport-y = log-scroll.visible-height - log-scroll.viewport-height;
        }
    }
}